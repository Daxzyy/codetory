{
  "rewrites": [
    {
      "source": "/raw/(.*)",
      "destination": "/scripts/$1"
    },
    {
      "source": "/(scripts/.*)",
      "destination": "/$1"
    },
    {
      "source": "/(data/.*)",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
